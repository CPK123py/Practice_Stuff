{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Compile All Java Files (core_java)",
      "type": "shell",
      "command": "javac",
      "args": [
        "-d",
        "${workspaceFolder}/core_java/bin",
        "${workspaceFolder}/core_java/src/*.java"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": {
        "owner": "java",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^([^:]*):([^:]*):([^:]*):(.*)$",
          "file": 1,
          "location": 2,
          "message": 4
        }
      }
    },
    {
      "label": "Run Java Program from core_java",
      "type": "shell",
      "command": "java",
      "args": [
        "-cp",
        "${workspaceFolder}/core_java/bin",
        "${fileBasenameNoExtension}"
      ],
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    }
  ]
}
